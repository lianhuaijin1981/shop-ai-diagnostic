# ===========================================
# 线下门店AI经营诊断系统 - 环境变量配置示例
# 复制此文件为 .env 后修改对应值
# ===========================================

# ============ API 服务配置 ============
PORT=3000
NODE_ENV=development

# ============ MongoDB 配置 ============
MONGODB_URI=mongodb://localhost:27017/shop-ai-diagnostic
MONGODB_USER=
MONGODB_PASSWORD=

# ============ Redis 配置 ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============ JWT 认证配置 ============
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ============ 前端配置 (Vite) ============
VITE_API_BASE_URL=http://localhost:3000/api
